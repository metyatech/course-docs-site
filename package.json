{
  "name": "course-docs-site",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shared site runtime for metyatech course documentation",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/metyatech/course-docs-site.git"
  },
  "bugs": {
    "url": "https://github.com/metyatech/course-docs-site/issues"
  },
  "homepage": "https://github.com/metyatech/course-docs-site#readme",
  "scripts": {
    "sync:content": "node scripts/sync-course-content.mjs",
    "dev": "node scripts/run-dev.mjs",
    "dev:inner": "node scripts/dev-inner.mjs",
    "start": "next start",
    "build": "npm run sync:content && next build",
    "postinstall": "patch-package",
    "postbuild": "pagefind --site .next/server/app --output-path public/_pagefind",
    "lint": "npm run typecheck && eslint .",
    "format": "prettier --check .",
    "audit": "npm audit",
    "typecheck": "npm run sync:content && next typegen && tsc --noEmit",
    "test": "npm run test:e2e-config && node --test --test-concurrency=1 tests/admin-mode-route-protection.test.mjs tests/import-asset-resolution.test.mjs tests/sync-course-content-link-mode.test.mjs && node scripts/test-e2e-matrix.mjs && npm run lint:contrast",
    "test:e2e-config": "node --test tests/e2e-course-defaults.test.mjs",
    "test:dev-switch": "node --test --test-concurrency=1 tests/dev-switch.test.mjs tests/admin-mode-route-protection.test.mjs tests/import-asset-resolution.test.mjs tests/sync-course-content-clears-next.test.mjs tests/sync-course-content-does-not-touch-source.test.mjs tests/submissions-route-source.test.mjs tests/mdx-boundary-source.test.mjs tests/e2e-content-source.test.mjs tests/intro-image-resolution.test.mjs tests/qspec-relative-image-resolution.test.mjs tests/asset-route-trace-config.test.mjs",
    "test:e2e": "playwright test -c tests/e2e/playwright.config.mjs",
    "lint:contrast": "playwright test -c tests/e2e/playwright.config.mjs tests/e2e/contrast.spec.cjs",
    "verify": "npm run lint && npm run test && npm run build",
    "prepare": "husky"
  },
  "dependencies": {
    "@mdx-js/react": "^3.1.1",
    "@metyatech/course-docs-platform": "github:metyatech/course-docs-platform#2a89406",
    "dotenv": "^17.2.3",
    "next": "^15.5.14",
    "nextra": "^4.6.1",
    "nextra-theme-docs": "^4.6.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.55.0",
    "@types/node": "^25.0.9",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.14",
    "eslint-config-prettier": "^10.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "pagefind": "^1.4.0",
    "patch-package": "^8.0.0",
    "prettier": "^3.4.2",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,mjs}": [
      "prettier --check",
      "eslint"
    ],
    "*.{json,md}": [
      "prettier --check"
    ]
  },
  "engines": {
    "node": ">=20.0"
  },
  "overrides": {
    "@chevrotain/cst-dts-gen": "11.1.2",
    "@chevrotain/gast": "11.1.2",
    "@chevrotain/regexp-to-ast": "11.1.2",
    "@chevrotain/types": "11.1.2",
    "@chevrotain/utils": "11.1.2",
    "@mermaid-js/parser": "1.1.0",
    "@xmldom/xmldom": "0.9.9",
    "brace-expansion": "5.0.5",
    "chevrotain": "11.1.2",
    "dompurify": "3.3.3",
    "flatted": "3.4.2",
    "lodash": "4.18.1",
    "lodash-es": "4.18.1",
    "mermaid": "11.14.0",
    "minimatch": "10.2.5",
    "micromatch": {
      "picomatch": "2.3.2"
    },
    "express": {
      "path-to-regexp": "0.1.13"
    },
    "qs": ">=6.14.2",
    "serialize-javascript": "7.0.5",
    "speech-rule-engine": "4.1.3",
    "svgo": "3.3.3",
    "terser-webpack-plugin": "5.4.0",
    "tinyglobby": {
      "picomatch": "4.0.4"
    },
    "yaml": "2.8.3"
  }
}
