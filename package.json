{
  "name": "course-docs-site",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shared site runtime for metyatech course documentation",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/metyatech/course-docs-site.git"
  },
  "bugs": {
    "url": "https://github.com/metyatech/course-docs-site/issues"
  },
  "homepage": "https://github.com/metyatech/course-docs-site#readme",
  "scripts": {
    "verify": "npm run format && npm run lint && npm run audit && npm run test",
    "sync:content": "node scripts/sync-course-content.mjs",
    "dev": "node scripts/run-dev.mjs",
    "dev:inner": "node scripts/dev-inner.mjs",
    "start": "next start",
    "build": "npm run sync:content && next build",
    "postinstall": "patch-package",
    "postbuild": "pagefind --site .next/server/app --output-path public/_pagefind",
    "lint": "npm run typecheck && eslint .",
    "format": "prettier --check .",
    "audit": "npm audit",
    "typecheck": "npm run sync:content && tsc --noEmit",
    "test": "npm run test:e2e",
    "test:dev-switch": "node --test tests/dev-switch.test.mjs",
    "test:e2e": "playwright test -c node_modules/@metyatech/course-docs-e2e/playwright.config.mjs"
  },
  "dependencies": {
    "@mdx-js/react": "^3.1.1",
    "@metyatech/course-docs-platform": "git+https://github.com/metyatech/course-docs-platform.git#main",
    "dotenv": "^17.2.3",
    "next": "^15.5.11",
    "nextra": "^4.6.1",
    "nextra-theme-docs": "^4.6.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@metyatech/course-docs-e2e": "git+https://github.com/metyatech/course-docs-e2e.git#main",
    "@playwright/test": "^1.55.0",
    "@types/node": "^25.0.9",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "eslint": "^9.19.0",
    "eslint-config-next": "^15.1.6",
    "eslint-config-prettier": "^10.0.1",
    "pagefind": "^1.4.0",
    "patch-package": "^8.0.0",
    "prettier": "^3.4.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0"
  }
}
