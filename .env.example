## Course content selection
# Recommended: keep secrets in `.env.local` and put only these variables in `.env.course.local`.
# Course selection values are intentionally not listed in this file.
# Put them in `.env.course.local` and `.env.e2e.local` instead.

# The Supabase values below are only needed for course selections that enable
# the submissions/comment flow through `@metyatech/course-docs-platform`.
# They are not required for `javascript-course-docs`.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_WORKS_BASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_DELETE_TOKEN=
COURSE_DOCS_LOCAL_SOURCE_MODE=
# Used as the single shared admin code for comment deletion and site-level
# admin mode when the selected content repo defines `siteConfig.adminMode.protectedLinks`.
