## Course content selection
# Recommended: keep secrets in `.env.local` and put only these variables in `.env.course.local`.
# Course selection values are intentionally not listed in this file.
# Put them in `.env.course.local` and `.env.e2e.local` instead.

# The Supabase values below are only needed for course selections that enable
# the submissions/comment flow through `@metyatech/course-docs-platform`.
# They are not required for `javascript-course-docs`.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_WORKS_BASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
COURSE_DOCS_LOCAL_SOURCE_MODE=

# ADMIN_MODE_TOKEN: the human-entered admin code. Compared only at login time.
# The value must NOT be reused as the cookie signing secret.
ADMIN_MODE_TOKEN=

# ADMIN_SESSION_SECRET: HMAC-SHA256 signing key for the admin session cookie.
# Generate with: openssl rand -base64 32
# Must be UTF-8 32 bytes or more. Short values disable the configured admin
# mode gate (the /api/admin/mode endpoint reports
# `invalid-admin-session-secret`), so production deployments with admin
# features MUST set this. Only `programming-course-docs` and
# `open-campus-unreal-90min` need this; the other four supported sites
# have no admin features and do not require it.
# NEVER reuse the same value as ADMIN_MODE_TOKEN.
ADMIN_SESSION_SECRET=
